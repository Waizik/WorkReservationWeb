@page "/admin"
@attribute [Authorize(Roles = "admin")]
@inject WorkReservationWeb.Web.Services.ReservationAdminApiClient AdminApiClient
@using WorkReservationWeb.Shared.Contracts

<PageTitle>Admin</PageTitle>

<h1>Admin</h1>

@if (AdminApiClient.UsesConfiguredClientPrincipal)
{
	<p class="alert alert-warning">
		Local development mode is injecting a configured admin principal header for these requests.
	</p>
}

<section class="mb-5">
	<h2 class="h4">Create Or Update Service Offer</h2>

	<div class="mb-3">
		<label for="serviceTitle" class="form-label">Title</label>
		<input id="serviceTitle" class="form-control" @bind="serviceTitle" />
	</div>

	<div class="mb-3">
		<label for="serviceDescription" class="form-label">Description</label>
		<textarea id="serviceDescription" class="form-control" @bind="serviceDescription"></textarea>
	</div>

	<div class="mb-3">
		<label for="serviceBasePrice" class="form-label">Base price</label>
		<input id="serviceBasePrice" type="number" step="0.01" class="form-control" @bind="serviceBasePrice" />
	</div>

	<div class="form-check mb-3">
		<input id="serviceActive" type="checkbox" class="form-check-input" @bind="serviceActive" />
		<label for="serviceActive" class="form-check-label">Active</label>
	</div>

	<button class="btn btn-primary" @onclick="SaveServiceOfferAsync" disabled="@isSavingServiceOffer">Save service offer</button>

	@if (!string.IsNullOrWhiteSpace(serviceOfferMessage))
	{
		<p class="mt-3 @serviceOfferMessageClass">@serviceOfferMessage</p>
	}

	@if (lastSavedServiceOffer is not null)
	{
		<div class="mt-3 card">
			<div class="card-body">
				<h3 class="h5 card-title">Last saved offer</h3>
				<p class="mb-1"><strong>Id:</strong> @lastSavedServiceOffer.Id</p>
				<p class="mb-1"><strong>Title:</strong> @lastSavedServiceOffer.Title</p>
				<p class="mb-0"><strong>Status:</strong> @(lastSavedServiceOffer.Active ? "Active" : "Inactive")</p>
			</div>
		</div>
	}
</section>

<section>
	<div class="d-flex justify-content-between align-items-center mb-3">
		<h2 class="h4 mb-0">Reservations</h2>
		<button class="btn btn-outline-secondary" @onclick="LoadReservationsAsync" disabled="@isLoadingReservations">Refresh</button>
	</div>

	@if (!string.IsNullOrWhiteSpace(reservationsErrorMessage))
	{
		<p class="text-danger">@reservationsErrorMessage</p>
	}
	else if (isLoadingReservations)
	{
		<p>Loading reservations...</p>
	}
	else if (reservations.Count == 0)
	{
		<p>No reservations found.</p>
	}
	else
	{
		<table class="table table-striped">
			<thead>
				<tr>
					<th>Created</th>
					<th>Customer</th>
					<th>Email</th>
					<th>Service</th>
					<th>Slot</th>
					<th>Status</th>
				</tr>
				</thead>
			<tbody>
				@foreach (var reservation in reservations)
				{
					<tr>
						<td>@reservation.CreatedAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
						<td>@reservation.CustomerName</td>
						<td>@reservation.CustomerEmail</td>
						<td>@reservation.ServiceOfferId</td>
						<td>@reservation.SlotId</td>
						<td>@reservation.Status</td>
					</tr>
				}
			</tbody>
		</table>
	}
</section>

@code {
	private readonly List<ReservationSummaryDto> reservations = [];

	private bool isLoadingReservations = true;
	private bool isSavingServiceOffer;
	private string? reservationsErrorMessage;
	private string? serviceOfferMessage;
	private string serviceOfferMessageClass = "text-success";

	private string serviceTitle = string.Empty;
	private string serviceDescription = string.Empty;
	private decimal serviceBasePrice;
	private bool serviceActive = true;

	private ServiceOfferDto? lastSavedServiceOffer;

	protected override async Task OnInitializedAsync()
	{
		await LoadReservationsAsync();
	}

	private async Task LoadReservationsAsync()
	{
		isLoadingReservations = true;
		reservationsErrorMessage = null;

		try
		{
			var loadedReservations = await AdminApiClient.GetReservationsAsync(CancellationToken.None);
			reservations.Clear();
			reservations.AddRange(loadedReservations);
		}
		catch
		{
			reservationsErrorMessage = "Failed to load reservations.";
		}
		finally
		{
			isLoadingReservations = false;
		}
	}

	private async Task SaveServiceOfferAsync()
	{
		serviceOfferMessage = null;

		if (string.IsNullOrWhiteSpace(serviceTitle) || string.IsNullOrWhiteSpace(serviceDescription))
		{
			serviceOfferMessageClass = "text-danger";
			serviceOfferMessage = "Title and description are required.";
			return;
		}

		isSavingServiceOffer = true;

		try
		{
			var request = new UpsertServiceOfferRequestDto(
				null,
				serviceTitle,
				serviceDescription,
				serviceBasePrice,
				null,
				serviceActive);

			lastSavedServiceOffer = await AdminApiClient.UpsertServiceOfferAsync(request, CancellationToken.None);
			serviceOfferMessageClass = "text-success";
			serviceOfferMessage = lastSavedServiceOffer is null
				? "Service offer request completed with no payload."
				: "Service offer saved.";
		}
		catch
		{
			serviceOfferMessageClass = "text-danger";
			serviceOfferMessage = "Failed to save service offer.";
		}
		finally
		{
			isSavingServiceOffer = false;
		}
	}
}